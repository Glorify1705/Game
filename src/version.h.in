#pragma once

// clang-format off
#ifndef _GAME_VERSION_H
#define _GAME_VERSION_H

#define GAME_VERSION_MAJOR @Game_VERSION_MAJOR@
#define GAME_VERSION_MINOR @Game_VERSION_MINOR@

#define EXPAND_AND_STRINGIFY(s) STRINGIFY(s)
#define STRINGIFY(s) #s

#define GAME_VERSION_MAJOR_STR EXPAND_AND_STRINGIFY(GAME_VERSION_MAJOR)
#define GAME_VERSION_MINOR_STR EXPAND_AND_STRINGIFY(GAME_VERSION_MINOR)

#define GAME_VERSION_STR GAME_VERSION_MAJOR_STR "." GAME_VERSION_MINOR_STR

#if defined(__GNUC__)
#if defined(__clang__)
#define COMPILER "clang++"
#else
#define COMPILER "g++"
#endif
#define COMPILER_VERSION __VERSION__
#elif defined(_MSC_VER)
#define COMPILER "msvc"
#define COMPILER_VERSION _MSC_FULL_VER
#else
#error Please add your compiler here.
#endif

// clang-format on

#endif
